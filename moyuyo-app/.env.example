# ========================================
# MOYUYO ATELIER 环境变量模板
# ========================================
# 复制本文件为 .env 并填写实际值：
#   cp .env.example .env
# 真实 .env 文件已在 .gitignore 中排除。
# ========================================

# API 基础地址（生产环境推荐填写 Cloudflare Workers 代理层）
VITE_API_BASE=https://your-wp-site.com/wp-json

# WordPress 站点地址（用于支付跳转、WebView 加载 WP 页面）
VITE_WP_BASE=https://your-wp-site.com

# WooCommerce REST API Consumer Key
VITE_CONSUMER_KEY=your_consumer_key_here

# WooCommerce REST API Consumer Secret
VITE_CONSUMER_SECRET=your_consumer_secret_here

# WP OAuth Server（MiniOrange）OAuth 凭证
# 在 WP 后台 → 插件 → 安装 "WP OAuth Server"
# WP OAuth Server → 客户端 → 添加客户端 → 创建 App → 获取 Client ID/Secret
VITE_OAUTH_CLIENT_ID=your_oauth_client_id
VITE_OAUTH_CLIENT_SECRET=your_oauth_client_secret

# 结算货币
VITE_CURRENCY=USD

# 主题模式：light / dark / system
VITE_THEME_MODE=system
